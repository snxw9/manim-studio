{
  "name": "manim-studio",
  "private": true,
  "workspaces": [],
  "scripts": {
    "root-start": "concurrently --names \"ENGINE,WEB\" --prefix-colors \"yellow,cyan\" \"npm run root-engine\" \"npm run root-web\"",
    "root-engine": "cd engine && uvicorn main:app --reload --port 8000",
    "root-web": "cd web && npm run dev",
    "root-install:all": "cd web && npm install",
    "root-test": "cd engine && pytest tests/ -v && cd ../web && npm test"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
